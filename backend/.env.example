NODE_ENV=production

DB_HOST=postgres
DB_PORT=5432
DB_USERNAME=replace_me
DB_PASSWORD=replace_me
DB_NAME=hrm
DB_SSL=false
DB_SSL_REJECT_UNAUTHORIZED=true

PORT=3000
FRONTEND_URL=https://hrm.example.com

JWT_ACCESS_SECRET=replace_with_long_random_value
JWT_REFRESH_SECRET=replace_with_different_long_random_value
USER_TOKEN_SECRET=replace_with_another_random_value

MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_SECURE=false
MAIL_USER=replace_me
MAIL_PASSWORD=replace_me
MAIL_FROM_NAME=HRM System
MAIL_FROM_ADDRESS=no-reply@example.com

ACCOUNT_ACTIVATION_TOKEN_EXPIRES_MINUTES=1440
PASSWORD_RESET_TOKEN_EXPIRES_MINUTES=30
DEFAULT_INITIAL_USER_PASSWORD=replace_me
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=replace_with_at_least_12_characters
# One-time safety switch for adopting migrations on an existing matching schema.
ALLOW_MIGRATION_BASELINE=false

CLOUDINARY_CLOUD_NAME=replace_me
CLOUDINARY_API_KEY=replace_me
CLOUDINARY_API_SECRET=replace_me
